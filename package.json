{
  "name": "blackbox-auction-hub",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace frontend\" \"npm run dev --workspace backend\"",
    "build": "npm run build --workspace frontend && npm run build --workspace backend",
    "test": "npm test --workspaces"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "concurrently": "^8.2.2",
    "prisma": "^5.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "tar": "^7.5.19",
    "esbuild": "^0.25.0"
  },
  "prisma": {
    "seed": "ts-node backend/prisma/seed.ts"
  }
}
