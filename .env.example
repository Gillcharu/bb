# =============================================================================
# Black Box Auction Hub — environment template
# Copy to `.env` and fill in real values. NEVER commit the real .env file.
# =============================================================================

# --- Runtime mode ---
NODE_ENV=production

# --- PostgreSQL (used by docker-compose to provision the database) ---
POSTGRES_USER=auction_app
POSTGRES_PASSWORD=replace_with_strong_db_password
POSTGRES_DB=auctiondb

# --- Database connection (local/non-docker runs; docker-compose derives its own) ---
# connection_limit / pool_timeout tune the Prisma connection pool for concurrent bidding load.
DATABASE_URL="postgresql://auction_app:replace_with_strong_db_password@localhost:5432/auctiondb?schema=public&connection_limit=20&pool_timeout=30"

# --- JSON Web Token secrets (REQUIRED, min 32 chars, must differ) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=replace_with_openssl_rand_hex_32

# --- HTTP server ---
PORT=4000
# Set to true when running behind a reverse proxy / load balancer so client IPs
# (rate limiting, audit logs) are read from X-Forwarded-For.
TRUST_PROXY=false

# --- CORS (REQUIRED in production): comma-separated list of EXACT allowed origins ---
CORS_ORIGIN="http://localhost:3000"

# --- Frontend build-time endpoints (inlined by Vite at build) ---
VITE_API_URL="http://localhost:4000/api"
VITE_SOCKET_URL="http://localhost:4000"

# --- First-run bootstrap (used once by `npm run bootstrap` to create the
#     initial company + admin account; remove afterwards) ---
BOOTSTRAP_COMPANY_NAME="Your Company Ltd"
BOOTSTRAP_ADMIN_EMAIL="admin@yourcompany.com"
BOOTSTRAP_ADMIN_PASSWORD="replace_with_initial_admin_password"

# --- Rate limiting (optional overrides; sensible defaults apply) ---
# AUTH_IP_MAX=15                  # auth attempts per IP per window
# AUTH_IP_WINDOW_MS=60000
# AUTH_ACCOUNT_MAX_BEFORE_DELAY=3 # failed logins before exponential backoff
# AUTH_ACCOUNT_WINDOW_MS=900000
# PUBLIC_MAX=45                   # public endpoint requests per IP per window
# PUBLIC_MAX_WINDOW_MS=60000
# AUTHED_MAX=150                  # authenticated requests per IP per window
# AUTHED_MAX_WINDOW_MS=60000
# BID_MAX=10                      # bids per user per window
# BID_WINDOW_MS=10000

# --- Logging ---
# LOG_LEVEL=info
